# App
APP_NAME=TravelAI Agent
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# DynamoDB (pay-per-request — no Postgres/RDS)
STORAGE_BACKEND=dynamo
AWS_REGION=me-central-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT=http://localhost:8001
LEADS_TABLE=travel-ai-leads-dev
BOOKINGS_TABLE=travel-ai-bookings-dev
SESSIONS_TABLE=travel-ai-sessions-dev
CONVERSATIONS_TABLE=travel-ai-conversations-dev
PRICE_ALERTS_TABLE=travel-ai-price-alerts-dev
EVENTS_TABLE=travel-ai-events-dev
REFERRALS_TABLE=travel-ai-referrals-dev
ITINERARIES_TABLE=travel-ai-itineraries-dev

# OpenAI
OPENAI_API_KEY=

# Admin portal login (GitHub Secret: PORTAL_API_KEY) — alternative to Cognito user
PORTAL_API_KEY=

# Vapi Voice AI
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
VAPI_PHONE_NUMBER_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER_UAE=+971XXXXXXXX
TWILIO_PHONE_NUMBER_INDIA=+91XXXXXXXXXX
TWILIO_WHITELIST_NUMBERS=+971501234567,+919876543210

# Duffel Flights
DUFFEL_API_TOKEN=
DUFFEL_ENV=test

# Stripe (Global + UAE cards)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Razorpay (India - RuPay, UPI)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=travel-ai-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Google Ads (Ad Intelligence)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# SerpAPI (competitor ad research)
SERPAPI_KEY=

# AWS S3 (recordings — set after SAM deploy)
AWS_S3_BUCKET=travel-ai-recordings

# SMTP (email nurture)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=travel@travelai.com
SMTP_PASS=
SITE_URL=http://localhost:8000

# Compliance
UAE_CALLING_HOURS_START=09:00
UAE_CALLING_HOURS_END=18:00
UAE_TIMEZONE=Asia/Dubai
INDIA_CALLING_HOURS_START=09:00
INDIA_CALLING_HOURS_END=20:00
INDIA_TIMEZONE=Asia/Kolkata
REQUIRE_OPT_IN=true

# Lead engine
LEAD_CALLBACK_DELAY_SECONDS=60
LEAD_HOT_SCORE_THRESHOLD=80
LEAD_WARM_SCORE_THRESHOLD=50
